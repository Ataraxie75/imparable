---
import Layout from '../layouts/Layout.astro';
import { RULES_VERSION } from '../lib/moteur/audit';

// E10 — la transparence EST le marketing (PRD §12) : toutes les règles
// R1–R7 et la grille A–E publiées, avec leurs textes.
const principes = [
  {
    titre: 'Déterminisme',
    texte:
      "Aucun modèle statistique, aucune IA. Chaque règle est du code vérifié par des tests adossés aux textes et aux arrêts — le site ne se construit pas si un seul test échoue.",
  },
  {
    titre: 'Humilité',
    texte:
      "Toute réponse ambiguë, tout cas non couvert produit une « vigilance », jamais un « conforme ». On préfère « faites vérifier ce point » à une fausse certitude.",
  },
  {
    titre: 'Périmètre',
    texte:
      "IMPARABLE vérifie la forme d'une convocation. Il ne délivre pas de conseil juridique et refuse de conclure sur les cas non modélisés (urgence, contentieux).",
  },
];

const regles = [
  { code: 'R1', titre: 'Point de départ (J1)', texte: "LRAR : lendemain de la première présentation (pas l'envoi, pas le retrait). Main propre : jour de la remise. LRE : lendemain de l'envoi.", source: 'art. 64, décret du 17 mars 1967' },
  { code: 'R2', titre: 'Durée N', texte: "N = max(21, délai du règlement). 21 jours est d'ordre public : toute saisie inférieure est ramenée à 21. Jusqu'à 90 jours.", source: 'art. 9, décret du 17 mars 1967' },
  { code: 'R3', titre: 'Dernier jour', texte: 'dernierJour = J1 + (N − 1). Le N-ième jour expire à minuit.', source: 'art. 9 et 64, décret du 17 mars 1967' },
  { code: 'R4', titre: "Première date légale d'AG", texte: "agLegale = J1 + N. L'assemblée ne peut se tenir qu'à partir du (N+1)-ième jour : le jour de l'AG ne compte jamais.", source: 'décret 1967 · Cass. 4 déc. 2025' },
  { code: 'R5', titre: 'Pas de prorogation', texte: "L'art. 642 al. 2 CPC ne s'applique pas : dimanches et jours fériés ne décalent rien.", source: 'jurisprudence constante' },
  { code: 'R6', titre: 'Verdict', texte: 'conforme si dateAG ≥ agLegale, sinon annulable. Sortie : verdict, première date légale, dernier jour, marge signée.', source: 'art. 42, loi du 10 juillet 1965' },
  { code: 'R7', titre: 'Hors périmètre', texte: "Convocation d'urgence : non modélisée. Le moteur ne rend jamais de verdict sur un cas non modélisé et renvoie vers un avocat.", source: 'art. 9 al. 3, décret du 17 mars 1967' },
];

const blocs = [
  { code: 'A', titre: 'Délai & notification', items: "Computation complète du délai (R1–R7) · mode de notification admis pour chaque copropriétaire · si LRE, accord exprès préalable du destinataire.", source: 'art. 9 et 64 décret 1967 · art. 42-1 loi 1965' },
  { code: 'B', titre: 'Mentions de la convocation', items: "Lieu, date et heure · ordre du jour énumérant chaque question · modalités de consultation des pièces justificatives des charges.", source: 'art. 9, 11 et 13, décret 1967' },
  { code: 'C', titre: 'Documents joints par résolution', items: 'Pour chaque résolution, la checklist des annexes exigées (comptes, budget, devis, contrat de syndic…) + le formulaire de vote par correspondance, toujours exigé.', source: 'art. 11 décret 1967 · art. 17-1 A loi 1965' },
  { code: 'D', titre: 'Majorité par résolution', items: 'La majorité annoncée est confrontée au régime de la Bibliothèque — générée depuis les mêmes fiches, donc aucune divergence possible. Hors référentiel → vigilance.', source: 'art. 24, 25 et 26, loi 1965' },
  { code: 'E', titre: 'Qualité du convocateur', items: "Syndic en exercice · mandat non expiré à la date d'envoi · conseil syndical, copropriétaire habilité ou administrateur provisoire → vigilance + renvoi.", source: 'art. 7 et 8, décret 1967' },
];
---

<Layout
  titre="Notre méthode"
  description="Comment IMPARABLE produit son verdict : un moteur déterministe, zéro IA, chaque règle publiée avec son texte. Les 7 règles de calcul du délai et les 5 blocs de contrôle des causes de nullité."
>
  <div class="conteneur section">
    <h1 class="section-titre titre-degrade">Notre méthode</h1>
    <p class="section-sous-titre">
      Le verdict est produit par un moteur déterministe : mêmes entrées, même sortie, toujours.
      Tout est public — voici l'intégralité des règles appliquées.
    </p>

    <div class="stats-band">
      <div class="stat"><div class="stat-chiffre">0</div><div class="stat-label">approximation · zéro IA</div></div>
      <div class="stat"><div class="stat-chiffre">7</div><div class="stat-label">règles de calcul du délai</div></div>
      <div class="stat"><div class="stat-chiffre">5</div><div class="stat-label">blocs de contrôle</div></div>
      <div class="stat"><div class="stat-chiffre">33</div><div class="stat-label">fiches vérifiées Légifrance</div></div>
    </div>

    <h2 class="section-titre" style="margin-top:56px;">Trois principes, non négociables</h2>
    <div class="principe-grille">
      {principes.map((p, i) => (
        <div class="carte">
          <div class="principe-num">{i + 1}</div>
          <h3>{p.titre}</h3>
          <p>{p.texte}</p>
        </div>
      ))}
    </div>

    <h2 class="section-titre" style="margin-top:56px;">Le calcul du délai, règle par règle</h2>
    <p class="section-sous-titre">Les 7 règles du moteur de délai (R1–R7), chacune avec son texte.</p>
    <div class="regle-grille">
      {regles.map((r) => (
        <div class="carte regle-carte">
          <span class="regle-code">{r.code}</span>
          <div class="regle-corps">
            <h4>{r.titre}</h4>
            <p>{r.texte}</p>
            <div class="regle-source">{r.source}</div>
          </div>
        </div>
      ))}
    </div>

    <h2 class="section-titre" style="margin-top:56px;">La grille des causes de nullité</h2>
    <p class="section-sous-titre">Les 5 blocs contrôlés par l'audit, chacun adossé à sa base légale.</p>
    <div class="grille-1" style="display:grid; gap:16px;">
      {blocs.map((b) => (
        <div class="carte bloc-carte">
          <span class="bloc-lettre">{b.code}</span>
          <div>
            <h3>{b.titre}</h3>
            <p>{b.items}</p>
            <div class="regle-source">{b.source}</div>
          </div>
        </div>
      ))}
    </div>

    <div class="carte" style="margin-top:40px; text-align:center;">
      <h3>Règles vérifiées au {RULES_VERSION}</h3>
      <p style="max-width:680px; margin:0 auto;">
        Sources : loi n°65-557 du 10 juillet 1965 · décret n°67-223 du 17 mars 1967 ·
        Cass. 3<sup>e</sup> civ., 4 décembre 2025. Chaque fiche porte la date de sa vérification
        Légifrance ; chaque attestation porte la version des règles appliquées.
      </p>
      <p style="margin-top:18px;">
        <a class="bouton bouton-voltage" href="/audit">Vérifier ma convocation</a>
      </p>
    </div>
  </div>
</Layout>
