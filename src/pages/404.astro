---
import Layout from '../layouts/Layout.astro';
---

<Layout titre="Page introuvable" description="Cette page n'existe pas ou plus.">
  <div class="conteneur section" style="text-align:center;">
    <h1>Page introuvable</h1>
    <p class="section-sous-titre">
      Cette adresse ne mène nulle part — contrairement à nos redirections, qui ne laissent
      jamais un 404 derrière elles.
    </p>
    <p>
      <a class="bouton bouton-voltage" href="/">Retour à l'accueil</a>
      <a class="bouton bouton-secondaire" href="/resolutions" style="margin-left:12px;">Parcourir la Bibliothèque</a>
    </p>
  </div>
</Layout>
