---
import { getCollection, getEntry, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Calculateur from '../../components/Calculateur';
import { LIBELLES_REGIME_COURT } from '../../lib/moteur/audit';

export async function getStaticPaths() {
  const guides = await getCollection('guides', ({ data }) => data.published);
  return guides.map((guide) => ({ params: { slug: guide.slug }, props: { guide } }));
}

interface Props {
  guide: CollectionEntry<'guides'>;
}

const { guide } = Astro.props;
const { Content, headings } = await guide.render();

const sommaire = headings.filter((h) => h.depth === 2);

const fichesLiees = (
  await Promise.all(guide.data.fichesLiees.map((slug) => getEntry('resolutions', slug)))
).filter((f): f is CollectionEntry<'resolutions'> => f !== undefined && f.data.published);

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      headline: guide.data.titre,
      description: guide.data.description,
      inLanguage: 'fr-FR',
      dateModified: guide.data.verifieLe,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Guides', item: new URL('/guides/', Astro.site).href },
        { '@type': 'ListItem', position: 2, name: guide.data.titre },
      ],
    },
  ],
};
---

<Layout titre={guide.data.titre} description={guide.data.description}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />

  <div class="conteneur section">
    <nav class="aide" aria-label="Fil d'Ariane" style="margin-bottom: 18px;">
      <a href="/guides">Guides anti-annulation</a> · {guide.data.titre}
    </nav>

    <div class="guide-entete">
      <h1>{guide.data.titre}</h1>
      <div class="guide-souligne"></div>
      {guide.data.accroche && <p class="guide-accroche">{guide.data.accroche}</p>}
    </div>

    <div class="fiche-grille" style="margin-top: 40px;">
      <article class="prose carte">
        {sommaire.length > 1 && (
          <div class="sommaire">
            <p class="sommaire-titre">Dans ce guide</p>
            <ol>
              {sommaire.map((h) => (
                <li><a href={`#${h.slug}`}>{h.text}</a></li>
              ))}
            </ol>
          </div>
        )}
        <Content />

        <div class="carte" style="margin-top:28px; text-align:center; background:var(--voile-violet); border:0;">
          <h3 style="margin-top:0;">Une convocation concernée&nbsp;?</h3>
          <p>Vérifiez les 10 causes de nullité, point par point — 3 minutes, verdict gratuit.</p>
          <a class="bouton bouton-voltage" href="/audit">Vérifier ma convocation</a>
        </div>
      </article>

      <aside>
        <Calculateur client:visible />
        {fichesLiees.length > 0 && (
          <div style="margin-top:24px;">
            <h3>Fiches résolution liées</h3>
            {fichesLiees.map((f) => (
              <a class="carte fiche-carte" style="margin-bottom:12px;" href={`/resolutions/${f.slug}/`}>
                <div class="fiche-meta">
                  <span class="fiche-cat">Résolution</span>
                  <span class="badge">{LIBELLES_REGIME_COURT[f.data.regime]}{f.data.contextuel && ' ⚠'}</span>
                </div>
                <h3>{f.data.titre}</h3>
              </a>
            ))}
          </div>
        )}
        <p class="aide" style="margin-top:18px;">Règles vérifiées au {guide.data.verifieLe}.</p>
      </aside>
    </div>
  </div>
</Layout>
